# ========== Environment ==========
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ========== OpenAI API ==========
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_BASE=https://api.openai.com/v1

# ========== Azure OpenAI (Alternative) ==========
USE_AZURE_OPENAI=false
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_LLM_DEPLOYMENT=gpt-4o-mini

# ========== Ollama (Optional Local LLM) ==========
USE_OLLAMA=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ========== Qdrant Vector Database ==========
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=qdrant-dev-key
QDRANT_COLLECTION_NAME=german-visa-docs

# ========== Redis Cache ==========
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# ========== SQLite State Store ==========
SQLITE_DB_PATH=./data/state.db

# ========== API Security ==========
API_KEY=dev-key-12345

# ========== RAG Optimization ==========
ENABLE_QUERY_EXPANSION=true

# ========== Ingestion Config ==========
INGESTION_SCHEDULE_INTERVAL_HOURS=24
CRAWLER_RATE_LIMIT_REQUESTS_PER_SECOND=2
CRAWLER_TIMEOUT_SECONDS=30

# ========== MLflow Tracking ==========
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=german-visa-rag

# ========== Reranker Service ==========
RERANKER_API_TYPE=mock
RERANKER_API_KEY=

# ========== GCP Deployment (if applicable) ==========
GCP_PROJECT_ID=
GCP_REGION=europe-west1
GCP_CLOUD_RUN_SERVICE_NAME=german-visa-rag-api
GOOGLE_APPLICATION_CREDENTIALS=

# ========== Qdrant Cloud (Production) ==========
QDRANT_CLOUD_URL=
QDRANT_CLOUD_API_KEY=
